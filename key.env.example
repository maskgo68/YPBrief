# YPBrief local secrets and runtime configuration.
# Copy this file to key.env and fill values locally.
# Do not commit key.env.

# -----------------------------------------------------------------------------
# Security settings
# Required before exposing the Web UI on a VPS or public network.
# Use a long random string. Leave empty only for trusted local development.
# -----------------------------------------------------------------------------
YPBRIEF_ACCESS_PASSWORD=

# -----------------------------------------------------------------------------
# YouTube API and transcript fetching
# YOUTUBE_DATA_API_KEY is used for metadata, channel and playlist discovery.
# yt-dlp is the primary subtitle route; cookies/proxy settings help with YouTube anti-bot blocks.
# Proxy is disabled by default. Enable it only when your server IP has poor YouTube access quality.
# -----------------------------------------------------------------------------
YOUTUBE_DATA_API_KEY=
YOUTUBE_PROXY_ENABLED=false
YOUTUBE_PROXY_HTTP=
YOUTUBE_PROXY_HTTPS=
IPROYAL_PROXY_HOST=
IPROYAL_PROXY_PORT=
IPROYAL_PROXY_USERNAME=
IPROYAL_PROXY_PASSWORD=
YT_DLP_COOKIES_FILE=./secrets/youtube-cookies.txt
YT_DLP_COOKIES_FROM_BROWSER=
YT_DLP_PROXY=
YT_DLP_SLEEP_INTERVAL=2
YT_DLP_MAX_SLEEP_INTERVAL=8
YT_DLP_RETRIES=3

# -----------------------------------------------------------------------------
# LLM provider settings
# LLM_PROVIDER selects the provider. Model names are not prefilled in this template
# because provider model catalogs change quickly.
# Add LLM_MODEL or a provider-specific *_MODEL field manually, or configure models in the Web UI.
# Supported providers: openai, gemini, siliconflow, claude, openrouter, xai, deepseek, custom_openai.
# Provider API keys are stored here; Web UI should only show masked/configured status.
# -----------------------------------------------------------------------------
LLM_PROVIDER=gemini
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
CUSTOM_OPENAI_API_KEY=
CUSTOM_OPENAI_BASE_URL=

# -----------------------------------------------------------------------------
# Daily digest scheduler settings
# Default production schedule: Beijing time 07:00, previous-day window only.
# SCHEDULER_MAX_VIDEOS_PER_SOURCE is a safety cap, not a target count.
# -----------------------------------------------------------------------------
SCHEDULER_ENABLED=false
SCHEDULER_TIMEZONE=Asia/Shanghai
SCHEDULER_RUN_TIME=07:00
SCHEDULER_DIGEST_LANGUAGE=zh
SCHEDULER_SOURCE_SCOPE=all_enabled
SCHEDULER_SOURCE_IDS=
SCHEDULER_MAX_VIDEOS_PER_SOURCE=10
SCHEDULER_SEND_EMPTY_DIGEST=true

# -----------------------------------------------------------------------------
# Delivery settings - Telegram
# Telegram sends only the daily digest.
# Long digests are split into numbered message parts.
# TELEGRAM_CHAT_ID must be a numeric/private chat id, group id, or @channelusername.
# -----------------------------------------------------------------------------
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_PARSE_MODE=Markdown
TELEGRAM_SEND_AS_FILE_IF_TOO_LONG=true

# -----------------------------------------------------------------------------
# Delivery settings - Feishu
# FEISHU_WEBHOOK_URL is the custom bot webhook URL from a Feishu group.
# FEISHU_SECRET is optional; fill it only if the bot uses signature verification.
# -----------------------------------------------------------------------------
FEISHU_ENABLED=false
FEISHU_WEBHOOK_URL=
FEISHU_SECRET=

# Telegram Bot Inbox lets the same bot receive a YouTube link and reply with a single-video summary.
# Keep disabled until the service is reachable through HTTPS and allowed ids are configured.
TELEGRAM_BOT_INBOX_ENABLED=false
TELEGRAM_BOT_WEBHOOK_SECRET=
TELEGRAM_BOT_HEADER_SECRET=
TELEGRAM_BOT_ALLOWED_CHAT_IDS=
TELEGRAM_BOT_ALLOWED_USER_IDS=
TELEGRAM_BOT_PUBLIC_BASE_URL=
TELEGRAM_BOT_MAX_LINKS_PER_MESSAGE=1
TELEGRAM_BOT_REUSE_EXISTING_SUMMARY=true

# -----------------------------------------------------------------------------
# Delivery settings - Email
# Email sends only the daily digest.
# SMTP password is never returned to the browser.
# EMAIL_TO accepts comma-separated recipients.
# -----------------------------------------------------------------------------
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
EMAIL_FROM=
EMAIL_TO=
EMAIL_SUBJECT_TEMPLATE=YPBrief 每日播客日报 - {{ run_date }}
EMAIL_ATTACH_MARKDOWN=true

# -----------------------------------------------------------------------------
# Runtime paths for local and Docker usage
# Keep these paths mounted as volumes in Docker so database, exports and logs survive container rebuilds.
# -----------------------------------------------------------------------------
YPBRIEF_DATA_DIR=./data
YPBRIEF_DB_PATH=./data/ypbrief.db
YPBRIEF_EXPORT_DIR=./exports
YPBRIEF_LOG_DIR=./logs
YPBRIEF_PROMPT_FILE=./prompts.yaml
