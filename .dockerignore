# Local working snapshots, public source/prompt examples, and planning notes.
# Docker only needs key.env.example plus application code; source/prompt YAML
# examples are for GitHub/local users and should not enter the image context.
sources.yaml
sources.example.yaml
prompts.yaml
prompts.example.yaml
PRD doc/
Project Evaluation/
# Root-level fallbacks in case internal docs are created outside PRD doc/.
findings.md
progress.md
task_plan.md
PRD*.md

# Files useful in the source tree but not needed to build the runtime image.
# GitHub Actions Lite runs from the repository, not from the Docker image.
.git/
.github/
examples/
tests/
scripts/
run.bat
README*.md
docker-compose.yml

